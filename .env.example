## Rename this file to ".env" and fill values
#
# Telegram bot token from @BotFather
BOT_TOKEN=PASTE_YOUR_BOT_TOKEN_HERE
#
# Comma-separated Telegram user IDs allowed to use the bot
# Example: 123456789,987654321
ALLOWED_USERS=

# Filter used when collecting/saving filtered certificates
SPECIALIZATION_FILTER=Олий таълим хизматлари

# Scraper browser: chrome or firefox
SCRAPER_BROWSER=chrome

# Headless mode for browser (true/false)
CHROME_HEADLESS=true

# Optional: set Chrome major version if auto-detection fails
# CHROME_VERSION_MAIN=145

# Warmup behavior
# SKIP_WARMUP=true  -> never warmup
# SKIP_WARMUP=false -> allow warmup according to WARMUP_MODE
SKIP_WARMUP=true

# always | adaptive | never
WARMUP_MODE=adaptive

